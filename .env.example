# =============================================================
#  PLANTILLA DE CONFIGURACIÓN — copia este archivo como ".env"
#  y rellena cada valor. NUNCA subas el archivo .env a internet.
# =============================================================

# --- Base de datos (Supabase) -------------------------------
# Botón "Connect" de Supabase > pestaña ORMs > Prisma (te da estas dos líneas).
DATABASE_URL="postgresql://...pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...pooler.supabase.com:5432/postgres"

# --- Supabase (API/Auth, para el dashboard) -----------------
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ...."
SUPABASE_SERVICE_ROLE_KEY="eyJ...."

# --- Login del dashboard (solo para crear el primer admin) --
# Se usan una sola vez al correr "npm run seed:admin". Después de
# crear el admin podés borrar estas tres líneas si querés.
SEED_ADMIN_EMAIL="admin@tu-agencia.com"
SEED_ADMIN_PASSWORD="poné-una-contraseña-fuerte"
SEED_ADMIN_NAME="Admin"

# --- Modelo de IA (LLM) -------------------------------------
# Por defecto: Google Gemini directo (requiere facturación activada en Google).
# La API key la obtienes en https://aistudio.google.com > Get API key.
LLM_API_KEY="xxxxxxxxxxxxxxxxx"
# Endpoint del proveedor.
LLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# Modelo a usar. gemini-2.5-flash usa bien las "funciones" (extrae datos del
# lead de forma fiable). flash-lite es más barato pero falla con funciones.
LLM_MODEL="gemini-2.5-flash"

# Runtime del agente: "direct" usa el proveedor LLM configurado arriba;
# "hermes" usa un profile Hermes dedicado mediante su API local.
AGENT_RUNTIME="direct"
HERMES_API_BASE_URL="http://127.0.0.1:8643/v1"
HERMES_API_KEY="replace-with-a-long-random-secret"
HERMES_MODEL="hernancasas"
HERMES_TIMEOUT_MS="60000"
HERMES_FALLBACK_TO_LLM="false"

# Token exclusivo de mínimo privilegio para que la tool guardar_lead de Hermes
# pueda llamar la API interna. Generá un valor aleatorio largo y no lo compartas
# con ninguna otra integración.
HERMES_CRM_API_TOKEN="replace-with-a-different-long-random-secret"

# --- Meta (común para WhatsApp, Messenger e Instagram) ------
# Lo inventas tú: una frase secreta para validar los webhooks de Meta.
META_VERIFY_TOKEN="pon-aqui-una-frase-secreta-larga"
# Secreto de la App de Meta (App Settings > Basic > App Secret).
META_APP_SECRET="xxxxxxxxxxxxxxxxx"

# --- WhatsApp Cloud API -------------------------------------
WHATSAPP_ACCESS_TOKEN="xxxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="xxxxxxxxxxxxxxxxx"

# --- Messenger / Instagram (se rellenan en la Fase 4) -------
PAGE_ACCESS_TOKEN=""
INSTAGRAM_ACCESS_TOKEN=""
